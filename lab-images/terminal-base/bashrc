# Cosmos Corp dev shell - kept friendly and beginner-safe.

# Quietly bail if not interactive.
case $- in
  *i*) ;;
    *) return ;;
esac

# History: append, share across shells, ignore dupes & space-prefixed commands.
shopt -s histappend
HISTCONTROL=ignoredups:ignorespace
HISTSIZE=2000
HISTFILESIZE=5000
PROMPT_COMMAND="history -a; ${PROMPT_COMMAND:-:}"

# Sensible default: colourful ls, git-aware-ish prompt, useful aliases.
alias ls='ls --color=auto'
alias ll='ls -lah --color=auto'
alias la='ls -A --color=auto'
alias grep='grep --color=auto'

# Prompt: cyan user@host, yellow cwd, green prompt char. No git plumbing yet -
# Daymari hasn't met git in chapter 1.
PS1='\[\033[01;36m\]\u@cosmos\[\033[00m\]:\[\033[01;33m\]\w\[\033[00m\]\$ '

# Welcome banner - shown once per shell. Missions can override / suppress by
# touching ~/.cosmos/no-banner before opening a shell.
if [ ! -f "$HOME/.cosmos/no-banner" ] && [ -z "$COSMOS_BANNER_SHOWN" ]; then
  export COSMOS_BANNER_SHOWN=1
  if [ -f /etc/cosmos/motd ]; then
    cat /etc/cosmos/motd
  fi
fi

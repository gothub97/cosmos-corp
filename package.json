{
  "name": "cosmos-corp",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "description": "A macOS RPG that teaches terminal, git, k8s, and FluxCD",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lab:build": "bash scripts/build-images.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-version.mjs",
    "release:tag": "node scripts/tag-release.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
